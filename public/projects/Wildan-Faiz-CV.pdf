<!doctype html>
<html lang="id">
  <head>
    <script type="module">import { injectIntoGlobalHook } from "/@react-refresh";
injectIntoGlobalHook(window);
window.$RefreshReg$ = () => {};
window.$RefreshSig$ = () => (type) => type;</script>

    <script type="module" src="/@vite/client"></script>

    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>Wildan Faiz | IT Portfolio</title>

    <meta
      name="description"
      content="Portofolio IT Wildan Faiz yang menampilkan project Web Development, Game Development, Automation, Discord Bot, dan Web3."
    />

    <meta
      name="keywords"
      content="Wildan Faiz, IT Portfolio, Web Developer, Laravel Developer, React Developer, Roblox Developer, Discord Bot, n8n Automation, Web3"
    />

    <meta name="author" content="Wildan Faiz" />
    <meta name="theme-color" content="#050816" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://profilwildan.netlify.app/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="Wildan.dev" />

    <meta
      property="og:title"
      content="Wildan Faiz | IT Portfolio"
    />

    <meta
      property="og:description"
      content="Personal IT Portfolio focused on Web Development, Game Development, Automation, Discord Bot, and Web3 projects."
    />

    <meta
      property="og:url"
      content="https://profilwildan.netlify.app/"
    />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary" />

    <meta
      name="twitter:title"
      content="Wildan Faiz | IT Portfolio"
    />

    <meta
      name="twitter:description"
      content="Personal IT Portfolio focused on Web, Game, Automation, Discord Bot, and Web3 projects."
    />
  </head>

  <body>
    <!--
      Hidden form agar Netlify bisa mendeteksi struktur form
      ketika website diproses saat deployment.
    -->
    <form
      name="contact"
      data-netlify="true"
      netlify-honeypot="bot-field"
      hidden
    >
      <input type="hidden" name="form-name" value="contact" />
      <input type="text" name="bot-field" />
      <input type="text" name="name" />
      <input type="email" name="email" />
      <input type="text" name="subject" />
      <textarea name="message"></textarea>
    </form>

    <div id="root"></div>

    <script type="module" src="/src/main.jsx"></script>
  </body>
</html>